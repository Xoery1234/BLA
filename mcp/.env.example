# BLA MCP — example environment variables
# Use Infisical in prod. Do NOT commit real secrets to git.
#
# Local dev flow (see PRD v2 r3 §2 Auth and docs/mcp/*.md §Auth):
#   infisical login
#   infisical run --env dev --path /bla/dev/<mcp> -- pnpm dev

# ── LLM MCP ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY comes from Infisical path /bla/dev/llm/anthropic
ANTHROPIC_API_KEY=

# ── Adobe MCP — Workfront (IMS S2S) ────────────────────────────────
# Infisical path /bla/dev/adobe/workfront/
ADOBE_WORKFRONT_CLIENT_ID=
ADOBE_WORKFRONT_CLIENT_SECRET=
ADOBE_WORKFRONT_ORG_ID=
ADOBE_WORKFRONT_TECHNICAL_ACCOUNT_ID=
ADOBE_WORKFRONT_TENANT=

# ── Adobe MCP — EDS admin API (non-IMS) ────────────────────────────
# Infisical path /bla/dev/adobe/eds/
ADOBE_EDS_ADMIN_API_KEY=
ADOBE_EDS_GITHUB_OWNER=Xoery1234
ADOBE_EDS_GITHUB_REPO=BLA

# ── Adobe MCP — DA.live (IMS user-backed, scope PENDING H4) ────────
# Infisical path /bla/dev/adobe/da-live/
BLA_DA_LIVE_ENABLED=false
ADOBE_DA_LIVE_SERVICE_USER_CLIENT_ID=
ADOBE_DA_LIVE_SERVICE_USER_CLIENT_SECRET=
ADOBE_DA_LIVE_SCOPE=

# ── Publish safety gate (NFR §6.2 triple-gate, gate 1) ─────────────
# DEFAULT OFF. Enabling requires paired per-brief flag and per-call ack.
BLA_ALLOW_LIVE_PUBLISH=false

# ── Infisical runtime auth (Universal Auth machine identity) ───────
INFISICAL_HOST=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=

# ── Observability (OTLP → Grafana Alloy → LGTM) ────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=bla-mcp-unset

# ── Postgres (orchestrator persistence) ────────────────────────────
DATABASE_URL=
